# Supabase project URL (Dashboard → Project Settings → API → Project URL)
SUPABASE_URL=

# Supabase anon/service key (Dashboard → Project Settings → API → anon or service_role key)
SUPABASE_KEY=

# Google Places API key (https://console.cloud.google.com/ → enable Places API → Credentials)
GOOGLE_PLACES_API_KEY=

# Enrichment provider: "none" (rule-based), "ollama" (local LLM), or "custom" (POST to ENRICHMENT_API_URL)
ENRICHMENT_PROVIDER=none

# Ollama — live discovery pipeline (when ENRICHMENT_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Timeout for live pipeline (~70s/call on CPU; 120s gives headroom without stalling jobs)
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_EXECUTIVE_CALLS=6

# Ollama — optional deep-clean script only (backend/scripts/refine_existing_companies.py)
OLLAMA_REFINEMENT_MODEL=qwen3
OLLAMA_REFINEMENT_TIMEOUT_SECONDS=420

# Custom enrichment API — only used when ENRICHMENT_PROVIDER=custom
# POST with Bearer token; body {"signals": {...}}; expect {"summary": "...", "lead_score": 0-100}
ENRICHMENT_API_KEY=
ENRICHMENT_API_URL=

# Comma-separated frontend origins allowed by CORS (include every port you use for Next.js dev)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# When true, 500 responses include exception message and traceback in JSON
DEBUG=true
